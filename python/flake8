[flake8]
jobs = 16
indent-style = space
indent-size = 4
continuation-style = aligned
max-line-length = 75
max-complexity = 10
ignore =
    E203,  # whitespace before ':'
    E221,  # multiple spaces before operator
    E402,  # module level import not at top of file
    E251,  # unexpected spaces around keyword / parameter equals
